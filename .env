# ──────────────────────────────────────────────────────────────
# TrendPulse configuration
# Copy to .env  →  docker compose up --build
# TrendPulse works out of the box with zero keys (Google Trends,
# Apple Podcasts, Reddit public JSON, Steam, news RSS are already
# real). Add keys below to upgrade sources to live API data.
# ──────────────────────────────────────────────────────────────

PORT=3000

# Region used for Google Trends + YouTube regionCode (ISO country)
GEO=US

# ── Twitch (https://dev.twitch.tv/console/apps) ───────────────
# Create an app → copy Client ID + Client Secret.
# The server exchanges them for an app access token automatically
# (client_credentials flow). No user login required.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── YouTube (https://console.cloud.google.com/apis/library/youtube.googleapis.com)
# Enable "YouTube Data API v3" → Create credentials → API key.
YOUTUBE_API_KEY=

# ── Reddit (https://www.reddit.com/prefs/apps) ────────────────
# Create a "script" app. Optional: if you omit these, TrendPulse
# falls back to Reddit's public JSON endpoints (rate-limited).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
